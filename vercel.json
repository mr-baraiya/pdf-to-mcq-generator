{
  "version": 2,

  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@3.1.0"
    }
  },

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
