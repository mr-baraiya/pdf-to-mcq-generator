{
  "version": 2,

  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",

  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@3.1.0"
    }
  },

  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
